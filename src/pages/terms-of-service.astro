---
import logoSquare from '../../logo.png';
import logoTransparent from '../../logo_withoutbg.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Terms of Service | GrowthHackAI</title>
    <link rel="icon" type="image/png" href={logoSquare.src} />
    <meta name="description" content="Terms of service for GrowthHackAI." />
  </head>
  <body>
    <header class="site-header">
      <a class="header-brand" href="/" aria-label="GrowthHackAI home">
        <img class="header-logo" src={logoTransparent.src} alt="" />
        <div>
          <strong>GrowthHackAI</strong>
          <span>AI solutions and growth systems</span>
        </div>
      </a>

      <a class="header-cta button button-secondary" href="/privacy-policy">Privacy</a>
    </header>

    <main class="policy-shell">
      <article class="policy-card">
        <p class="eyebrow">Terms of Service</p>
        <h1>Simple terms for a simple service.</h1>
        <p class="lede">
          By using this website or working with GrowthHackAI, you agree to communicate honestly, use the services responsibly, and review deliverables in a timely way.
        </p>

        <section>
          <h2>Services</h2>
          <p>Scope, timelines, and pricing are defined per project and confirmed before work begins.</p>
        </section>

        <section>
          <h2>Payments</h2>
          <p>Invoices are due as agreed in the project terms. Work may pause if payment is overdue.</p>
        </section>

        <section>
          <h2>Liability</h2>
          <p>We aim for high-quality outcomes, but results depend on many external factors outside our control.</p>
        </section>
      </article>

      <footer class="site-footer">
        <p>© 2026 GrowthHackAI. All rights reserved.</p>
        <a href="/">Back home</a>
      </footer>
    </main>
  </body>
</html>

<style>
  :global(:root) {
    color-scheme: dark;
    --text: rgba(247, 250, 255, 0.96);
    --muted: rgba(209, 220, 240, 0.72);
  }

  :global(html) {
    scroll-behavior: smooth;
    background: linear-gradient(180deg, #03050b 0%, #070b14 60%, #03050b 100%);
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, rgba(36, 111, 255, 0.16), transparent 28%), #02040a;
  }

  :global(*) {
    box-sizing: border-box;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  .site-header,
  .policy-shell {
    width: min(960px, calc(100vw - 2rem));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    padding: 0.9rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    backdrop-filter: blur(18px);
  }

  .site-header::before {
    content: "";
    position: absolute;
    inset: 0;
    margin-inline: -1rem;
    border-radius: 999px;
    background: rgba(5, 10, 19, 0.58);
    border: 1px solid rgba(84, 146, 255, 0.16);
    z-index: -1;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .header-logo {
    width: 2.6rem;
    height: 2.6rem;
    object-fit: cover;
    border-radius: 0.8rem;
  }

  .header-brand strong,
  .header-brand span {
    display: block;
    line-height: 1.1;
  }

  .header-brand span,
  .lede,
  section p,
  .site-footer {
    color: var(--muted);
  }

  .header-brand strong {
    color: var(--text);
  }

  .button {
    border-radius: 999px;
    padding: 0.9rem 1.3rem;
    font-weight: 700;
  }

  .button-secondary {
    border: 1px solid rgba(122, 176, 255, 0.34);
    background: rgba(8, 14, 27, 0.72);
  }

  .policy-shell {
    padding: 1rem 0 3rem;
  }

  .policy-card {
    border: 1px solid rgba(84, 146, 255, 0.22);
    border-radius: 28px;
    padding: clamp(1.25rem, 4vw, 2.5rem);
    background: linear-gradient(180deg, rgba(11, 18, 34, 0.78), rgba(5, 10, 19, 0.9));
    backdrop-filter: blur(18px);
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.34em;
    color: #4fa1ff;
    font-size: 0.78rem;
    font-weight: 700;
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  h1 {
    margin-top: 0.6rem;
    font-size: clamp(2.4rem, 6vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
    max-width: 9ch;
  }

  .lede {
    margin-top: 1rem;
    max-width: 60ch;
    line-height: 1.8;
  }

  section {
    margin-top: 1.5rem;
  }

  h2 {
    font-size: 1.15rem;
    margin-bottom: 0.45rem;
  }

  .site-footer {
    padding: 1rem 0 0;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-footer a {
    color: #4fa1ff;
  }

  @media (max-width: 720px) {
    .site-header {
      flex-direction: column;
      align-items: stretch;
    }

    .header-cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
